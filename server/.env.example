# Copy to server/.env and fill in for your network. app/config.py loads it at
# startup; real environment variables take precedence. server/.env is gitignored.

# Pre-fill the dashboard "Add a node" flash form (saves retyping per device).
SENSORNET_WIFI_SSID=YourWiFiName
SENSORNET_WIFI_PASS=YourWiFiPassword
SENSORNET_SERVER_URL=http://192.168.0.100:8000

# Other optional overrides (defaults shown):
# SENSORNET_HOST=0.0.0.0
# SENSORNET_PORT=8000
# SENSORNET_DB_PATH=./data/sensornet.db
